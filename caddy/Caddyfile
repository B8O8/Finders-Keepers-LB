{
	email {$ACME_EMAIL}
}

# Customer storefront
{$WEB_DOMAIN}, www.{$WEB_DOMAIN} {
	encode gzip zstd
	reverse_proxy web:3000
}

# Admin panel
{$ADMIN_DOMAIN} {
	encode gzip zstd
	reverse_proxy admin:3000
}

# API, and uploaded media at /uploads/* - one host, no separate media domain.
{$API_DOMAIN} {
	encode gzip zstd

	# Media is served by MinIO, not the API.
	#
	# These MUST be `handle` blocks, not two bare `reverse_proxy` lines. Caddy
	# sorts directives rather than running them in file order, and a
	# matcher-less `reverse_proxy` matches every request - so a plain
	# `reverse_proxy api:3000` swallows /uploads/* no matter what precedes it.
	# `handle` blocks are mutually exclusive and evaluated in order: first match
	# wins, everything else falls through.
	#
	# The bucket is named "uploads", and MinIO serves objects at /<bucket>/<key>,
	# so /uploads/product/<uuid>.jpg maps onto the object exactly - no rewrite,
	# no path stripping, and every URL already stored in the database keeps
	# working. Renaming the bucket breaks every image on the site.
	handle /uploads/* {
		# Read-only at the edge. The bucket policy already grants anonymous
		# GetObject and nothing else, but refusing here keeps the S3 write API
		# off the internet entirely rather than trusting a policy to stay right.
		@write not method GET HEAD
		respond @write 405

		# Images are immutable (server-generated UUID filenames), so cache hard.
		header Cache-Control "public, max-age=2592000, immutable"

		reverse_proxy minio:9000
	}

	# Everything else is the API.
	handle {
		reverse_proxy api:3000
	}
}
