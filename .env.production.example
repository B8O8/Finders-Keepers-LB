# ============================================================
# Finders Keepers — production environment
# Copy this file to ".env" on the server and fill in REAL values.
# NEVER commit the real .env (it is gitignored).
# ============================================================

# ---- Domains (point these DNS A-records at your server IP) ----
WEB_DOMAIN=finderskeeperslb.com
ADMIN_DOMAIN=admin.finderskeeperslb.com
API_DOMAIN=api.finderskeeperslb.com
ACME_EMAIL=charbel_makhlouf76@live.com
STORE_NAME=Finders Keepers

# ---- Postgres (self-hosted in the stack) ----
POSTGRES_USER=fkadmin
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=finders_keepers

# ---- JWT secrets — generate each with: openssl rand -hex 32 ----
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
CUSTOMER_JWT_SECRET=CHANGE_ME
CUSTOMER_JWT_REFRESH_SECRET=CHANGE_ME

# ---- Supabase storage (product images) ----
SUPABASE_URL=https://hqxfscxufcugkdpecofg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_supabase_service_role_key
SUPABASE_BUCKET=products

# ---- Mail (Hostinger SMTP) ----
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USER=your@email.com
MAIL_PASSWORD=CHANGE_ME_mail_password
MAIL_FROM=Finders Keepers LB <noreply@finderskeeperslb.com>
